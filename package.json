{
  "name": "webperf-selfhosted",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bunx concurrently -n console,api,probe,scheduler \"bun run dev:console\" \"bun run dev:api\" \"bun run dev:probe\" \"bun run dev:scheduler\"",
    "dev:parallel:cloud": "bash tooling/scripts/dev-parallel-cloud.sh",
    "dev:browser-audit-worker": "PORT=8081 bun run --cwd apps/browser-audit-worker dev",
    "dev:console": "bash tooling/scripts/dev-console.sh",
    "dev:console:cf": "bun run --cwd apps/console dev:cf",
    "dev:api": "bash tooling/scripts/dev-api.sh",
    "dev:scheduler": "bun run --cwd apps/scheduler dev",
    "dev:web": "bun run dev:console",
    "dev:web:cf": "bun run dev:console:cf",
    "dev:probe": "bash tooling/scripts/dev-probe.sh",
    "build": "bun run --cwd apps/console build",
    "build:browser-audit-worker": "bun run --cwd apps/browser-audit-worker build",
    "build:cf": "bun run --cwd apps/console build:cf",
    "check:boundaries": "bun run tooling/scripts/check-boundaries.ts && bun run tooling/scripts/check-retired-paths.ts",
    "check:openapi": "bun run tooling/scripts/check-openapi.ts",
    "check": "bun run check:boundaries && bun run check:openapi && bun run types:cf:check && bun run --cwd apps/console check && bun run --cwd apps/api check && bun run --cwd apps/scheduler check && bun run --cwd apps/browser-audit-worker check && bunx tsc -p packages/contracts/tsconfig.json --noEmit && bunx tsc -p packages/domain-core/tsconfig.json --noEmit && bunx tsc -p packages/report-core/tsconfig.json --noEmit && bunx tsc -p packages/config/tsconfig.json --noEmit && bunx svelte-check --tsconfig packages/ui/tsconfig.json",
    "test:report-core": "bun test packages/report-core/test/*.test.ts",
    "test:probe": "cargo test --workspace --manifest-path apps/probe-rs/Cargo.toml",
    "smoke:console": "bash tooling/scripts/smoke-web.sh",
    "smoke:console:parallel:cloud": "SELFHOST_CONSOLE_PORT=${SELFHOST_PARALLEL_CONSOLE_PORT:-4174} bash tooling/scripts/smoke-web.sh",
    "smoke:web": "bun run smoke:console",
    "smoke:compose": "bash tooling/scripts/smoke-compose.sh",
    "smoke:compose:browser-audit": "COMPOSE_PROFILE=browser-audit bash tooling/scripts/smoke-compose.sh",
    "capture:console:baselines": "bash tooling/scripts/capture-console-baselines.sh",
    "capture:console:baselines:parallel:cloud": "BASE_URL=${SELFHOST_PARALLEL_CONSOLE_BASE_URL:-http://localhost:4174} bash tooling/scripts/capture-console-baselines.sh",
    "compose:config": "docker compose --env-file infra/docker-compose/.env.example -f infra/docker-compose/docker-compose.yml config >/dev/null",
    "ui:normalize-imports": "bun tooling/scripts/normalize-ui-imports.ts",
    "ui:jsrepo:add": "jsrepo add",
    "ui:jsrepo:add:extras": "jsrepo add --cwd packages/ui --registry @ieedan/shadcn-svelte-extras && bun run ui:normalize-imports",
    "ui:jsrepo:update": "jsrepo update --cwd packages/ui && bun run ui:normalize-imports",
    "ui:jsrepo:mcp:codex": "jsrepo config mcp --client codex",
    "types:cf": "bun run --cwd apps/console types:cf",
    "types:cf:check": "bun run --cwd apps/console types:cf:check",
    "sampo:add": "sampo add",
    "sampo:release": "sampo release",
    "sampo:release:dry-run": "sampo release --dry-run",
    "sampo:publish": "sampo publish"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@lucide/svelte": "^1.7.0",
    "@types/bun": "^1.3.11",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "1.0.0-beta.21",
    "jsrepo": "^3.7.0",
    "playwright": "^1.54.2",
    "runed": "^0.37.1",
    "shadcn-svelte": "^1.2.7",
    "svelte-toolbelt": "^0.10.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "typescript": "^5.9.3"
  }
}
