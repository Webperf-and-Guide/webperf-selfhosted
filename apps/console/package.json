{
  "name": "webperf-console",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "dev:cf": "bun run build:cf && wrangler pages dev .svelte-kit/cloudflare --port 5173",
    "build": "WEBPERF_CONSOLE_ADAPTER=node bunx --bun vite build",
    "build:cf": "WEBPERF_CONSOLE_ADAPTER=cloudflare bunx --bun vite build",
    "build:selfhost": "bun run build",
    "preview": "bunx --bun vite preview",
    "start": "bun ./build/index.js",
    "deploy:staging": "bun run build && wrangler pages deploy .svelte-kit/cloudflare --project-name webperf-console --branch staging",
    "deploy:production": "bun run build && wrangler pages deploy .svelte-kit/cloudflare --project-name webperf-console --branch main",
    "prepare": "svelte-kit sync || echo ''",
    "types:cf": "wrangler types src/cloudflare-env.d.ts --include-runtime false --strict-vars false",
    "types:cf:check": "bun ../../tooling/scripts/check-wrangler-types.ts --cwd . --output src/cloudflare-env.d.ts --config wrangler.jsonc",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "^1.3.11",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@orpc/client": "^1.13.14",
    "@orpc/contract": "^1.13.14",
    "@sveltejs/adapter-node": "^5.3.1",
    "@tanstack/svelte-query": "^6.1.16",
    "@webperf/contracts": "workspace:*",
    "@webperf/domain-core": "workspace:*",
    "@webperf/config": "workspace:*",
    "@webperf/report-core": "workspace:*",
    "@webperf/ui": "workspace:*"
  }
}
